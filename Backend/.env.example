# ===========================================
# WellSync AI — Backend Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# -------------------------------------------
# Database (Neon Postgres)
# -------------------------------------------
# Format: postgresql+asyncpg://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/wellsync?sslmode=require

# -------------------------------------------
# AI — Groq (low-latency LLM for explanations)
# -------------------------------------------
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# -------------------------------------------
# OCR — Ollama (local Gemma 4 + fallback)
# -------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PRIMARY_MODEL=gemma4
OLLAMA_FALLBACK_MODEL=llama3.2-vision

# Optional: external OCR API fallback (e.g. Google Cloud Vision)
GOOGLE_CLOUD_VISION_API_KEY=

# -------------------------------------------
# Voice — Vapi (webhook secret for validation)
# -------------------------------------------
VAPI_WEBHOOK_SECRET=your_vapi_webhook_secret_here

# -------------------------------------------
# App settings
# -------------------------------------------
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# -------------------------------------------
# Optional: PostHog analytics (server-side)
# -------------------------------------------
POSTHOG_API_KEY=
